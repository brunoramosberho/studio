enum PackageType {
  OFFER
  PACK
  SUBSCRIPTION
  ON_DEMAND_SUBSCRIPTION
}

model Package {
  id                String      @id @default(cuid())
  name              String
  description       String?
  type              PackageType @default(PACK)
  credits           Int?
  validDays         Int
  price             Float
  currency          String      @default("MXN")
  isPromo           Boolean     @default(false)
  isActive          Boolean     @default(true)
  stripePriceId     String?
  tenantId          String
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  countryId         String?
  country           Country?    @relation(fields: [countryId], references: [id])
  classTypes        ClassType[] @relation("PackageClassTypes")
  recurringInterval String?
  sortOrder         Int         @default(0)

  allowGuests         Boolean @default(false)
  maxGuestsPerBooking Int?
  monthlyGuestPasses  Int?

  // When true, members holding this package (or subscription) also get access
  // to the studio's on-demand video catalogue without needing a separate
  // ON_DEMAND_SUBSCRIPTION. Used to bundle on-demand into existing unlimited
  // tiers without adding a second Stripe charge.
  includesOnDemand Boolean @default(false)

  // Soft-delete marker. We hard-delete a Package when nothing references it,
  // but if there are existing UserPackage / MemberSubscription rows pointing at
  // it (FK with no cascade), we instead stamp deletedAt + flip isActive so the
  // catalog hides it everywhere while preserving historical purchases.
  deletedAt DateTime?

  userPackages        UserPackage[]
  memberSubscriptions MemberSubscription[]
  creditAllocations   PackageCreditAllocation[]
  onDemandConfigs     OnDemandConfig[]

  @@index([countryId])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model MemberSubscription {
  id                   String    @id @default(cuid())
  tenantId             String
  userId               String
  packageId            String
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String // 'active' | 'past_due' | 'canceled' | 'paused' | 'trialing' | 'incomplete'
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  pausedAt             DateTime?
  resumesAt            DateTime?
  canceledAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])

  @@unique([tenantId, userId, packageId])
  @@index([tenantId])
  @@index([userId])
  @@index([status])
}

model UserPackage {
  id              String                   @id @default(cuid())
  userId          String
  user            User                     @relation(fields: [userId], references: [id])
  packageId       String
  package         Package                  @relation(fields: [packageId], references: [id])
  tenantId        String
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  creditsTotal    Int?
  creditsUsed     Int                      @default(0)
  expiresAt       DateTime
  stripePaymentId String?
  status          UserPackageStatus        @default(ACTIVE)
  revokedAt       DateTime?
  revokedReason   String? // "payment_failed" | "chargeback" | "refund" | "manual"
  purchasedAt     DateTime                 @default(now())
  creditUsages    UserPackageCreditUsage[]
  debts           Debt[]

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
  @@index([status])
}

enum UserPackageStatus {
  ACTIVE
  PENDING_PAYMENT
  PAYMENT_FAILED
  REVOKED
  DISPUTED
}

model PackageCreditAllocation {
  id          String    @id @default(cuid())
