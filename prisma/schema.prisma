// ── Revenue recognition (ASC 606 / IFRS 15, tenant-scoped) ──
//
// Invariant: classes never generate revenue directly. Revenue comes from packs,
// unlimited subscriptions, drop-ins, and penalties. Classes are cost centers
// that *attract* revenue through attribution.
//
// Entitlement is the accounting overlay for everything a member has paid for
// that can be consumed or has expired. It unifies bonos (packs), unlimited
// subscriptions, drop-ins, and penalties. It does NOT replace UserPackage or
// MemberSubscription — it mirrors them so RevenueEvent has a single stable FK
// target.
//
// RevenueEvent is the single source of truth for recognized revenue. Every
// recognized cent lives here, attributed either to a booking (→ class/coach/
// time slot) or to breakage (pack expired, unlimited unconsumed). Totals
// reconcile to recognized revenue for any given month.

enum EntitlementType {
  pack
  unlimited
  dropin
  penalty
  on_demand
}

enum EntitlementStatus {
  active
  exhausted
  expired
  cancelled
}

model Entitlement {
  id                   String  @id @default(cuid())
  tenantId             String
  userId               String
  // Optional links to the SKU / source. packageId set for pack/unlimited/dropin
  // originating from the Package catalog. memberSubscriptionId set for
  // unlimited subscriptions so we can map one entitlement per billing period.
  // userPackageId set for entitlements backfilled from existing UserPackage.
  packageId            String?
  userPackageId        String? @unique
  memberSubscriptionId String?
  // For dropin/penalty only: the class this entitlement was consumed against.
  classId              String?

  type   EntitlementType
  status EntitlementStatus @default(active)

  totalAmountCents Int
  currency         String @default("eur")
  creditsTotal     Int? // N for pack; null for unlimited/dropin/penalty
  creditsUsed      Int    @default(0)

  periodStart DateTime
  periodEnd   DateTime

  purchasedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  classRef      Class?         @relation(fields: [classId], references: [id])
  revenueEvents RevenueEvent[]
  bookings      Booking[]      @relation("SourceEntitlement")

  @@index([tenantId, status])
  @@index([tenantId, type, periodEnd])
  @@index([userId, status])
  @@index([periodEnd])
  @@index([memberSubscriptionId])
  @@index([classId])
}

enum RevenueEventType {
  booking // consumption of a class (pack, dropin, or unlimited-allocated)
  daily_accrual // unlimited subscription daily pro-rata (intermediate; excluded from reports)
  expiration_breakage // pack credits expired unused
  monthly_breakage // unlimited MRR not consumed in the month
  penalty // late-cancel / no-show fee
  reversal // reserved for refunds/cancellations (not emitted in v1)
}

model RevenueEvent {
  id            String           @id @default(cuid())
  tenantId      String
  entitlementId String
  eventDate     DateTime         @db.Date
  amountCents   Int
  type          RevenueEventType
  bookingId     String?
  classId       String?
  metadata      Json?
  createdAt     DateTime         @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entitlement Entitlement @relation(fields: [entitlementId], references: [id], onDelete: Cascade)
  booking     Booking?    @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  classRef    Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)

  // Idempotency guard: re-running daily accrual or pack expiration for the
  // same entitlement/date/type is a no-op at the DB level.
  @@unique([entitlementId, eventDate, type], name: "uniq_entitlement_date_type")
  @@index([tenantId, eventDate])
  @@index([tenantId, type, eventDate])
  @@index([entitlementId])
  @@index([bookingId])
  @@index([classId])
}

// ── On-Demand Videos (tenant-scoped) ──
//
// Library of pre-recorded classes streamed via Cloudflare Stream. Members with
// an active ON_DEMAND_SUBSCRIPTION (or any package with includesOnDemand=true)
// get gated access. Playback uses signed URLs minted on demand by the backend.
//
// Anti-piracy enforcement (V1): signed URL with 1h TTL, IP binding via JWT
// accessRules, and a 1-stream-per-user cap enforced via OnDemandStreamSession.

enum OnDemandVideoStatus {
  processing
  ready
  errored
}

model OnDemandVideo {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  cloudflareStreamUid String              @unique
  status              OnDemandVideoStatus @default(processing)
  published           Boolean             @default(false)

  title       String
  description String?

  coachProfileId String?
  coachProfile   CoachProfile? @relation(fields: [coachProfileId], references: [id], onDelete: SetNull)

  classTypeId String?
  classType   ClassType? @relation(fields: [classTypeId], references: [id], onDelete: SetNull)

  level Level @default(ALL)

  durationSeconds Int?
  widthPx         Int?
  heightPx        Int?

  thumbnailUrl           String?
  cloudflareThumbnailUrl String?

  viewCount Int @default(0)

  errorMessage String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  streamSessions OnDemandStreamSession[]

  @@index([tenantId, published])
  @@index([tenantId, status])
  @@index([coachProfileId])
  @@index([classTypeId])
}

// Singleton-per-tenant config for the on-demand product (price, copy, link to
// the Stripe Package SKU). Use `upsert` with the unique tenantId.
model OnDemandConfig {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enabled     Boolean @default(false)
  description String?

  packageId String?
  package   Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OnDemandSessionEndReason {
  user_ended
  heartbeat_timeout
  superseded
}

// One row per active playback session. The player heartbeats every 30s. A new
// playback supersedes any previous active session for the same (user, tenant)
// pair — the displaced session is marked endedReason=superseded so the old
// client can detect it and surface a "viewing stopped" message. Stale sessions
// (no heartbeat for >90s) are cleaned up by the cron job.
model OnDemandStreamSession {
  id       String        @id @default(cuid())
  tenantId String
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId  String
  video    OnDemandVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)

  startedAt       DateTime                  @default(now())
  lastHeartbeatAt DateTime                  @default(now())
  endedAt         DateTime?
  endedReason     OnDemandSessionEndReason?

  clientIp  String?
  userAgent String? @db.Text

  @@index([tenantId, userId, endedAt])
  @@index([videoId])
  @@index([lastHeartbeatAt])
}

// ── Spark AI Feature Requests ──

model SparkFeatureRequest {
  id          String    @id @default(cuid())
  tenantId    String
  adminUserId String
  request     String    @db.Text
  category    String?
  sparkNote   String?   @db.Text
  adminName   String?
  studioName  String?
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([isResolved, createdAt])
}

// ── Class Substitutions ──
//
// A coach who can't teach an upcoming class can open a substitution request,
// either to all eligible coaches (OPEN) or to a specific coach (DIRECT).
// On acceptance, the class's coachId is reassigned and the original coach is
// snapshotted on Class.originalCoachId so the UI can flag a substitution to
// already-booked members.

enum SubstitutionMode {
  OPEN
  DIRECT
}

enum SubstitutionStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  EXPIRED
}

model SubstitutionRequest {
  id                String             @id @default(cuid())
  tenantId          String
  classId           String
  requestingCoachId String
  originalCoachId   String
  targetCoachId     String?
  acceptedByCoachId String?
  mode              SubstitutionMode
  status            SubstitutionStatus @default(PENDING)
  note              String?            @db.Text
  rejectionNote     String?            @db.Text
  notifiedCoachIds  String[]           @default([])
  createdAt         DateTime           @default(now())
  respondedAt       DateTime?

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  requestingCoach CoachProfile  @relation("SubstitutionRequestingCoach", fields: [requestingCoachId], references: [id])
  originalCoach   CoachProfile  @relation("SubstitutionOriginalCoach", fields: [originalCoachId], references: [id])
  targetCoach     CoachProfile? @relation("SubstitutionTargetCoach", fields: [targetCoachId], references: [id])
  acceptedByCoach CoachProfile? @relation("SubstitutionAcceptedCoach", fields: [acceptedByCoachId], references: [id])

  @@index([tenantId, status])
  @@index([classId])
  @@index([requestingCoachId])
  @@index([targetCoachId, status])
}
