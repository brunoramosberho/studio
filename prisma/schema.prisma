  amount          Float
  currency        String    @default("eur")
  paymentMethod   String    // 'card' | 'cash' | 'saved_card'
  type            String    // 'subscription' | 'package' | 'product' | 'penalty'
  concept         String?
  conceptSub      String?
  status          String    @default("completed") // 'completed' | 'refunded'
  processedById   String?
  fee             Float?
  netAmount       Float?
  availableOn     DateTime?
  isFeesEstimated Boolean   @default(false)
  referenceId     String?
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member      User?  @relation("PosMember", fields: [memberId], references: [id])
  processedBy User?  @relation("PosProcessedBy", fields: [processedById], references: [id])

  @@index([tenantId])
  @@index([memberId])
  @@index([tenantId, createdAt])
}

model StripeCustomer {
  id                     String   @id @default(cuid())
  tenantId               String
  memberId               String
  stripeCustomerId       String   @unique
  defaultPaymentMethodId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  member User   @relation("UserStripeCustomers", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([tenantId, memberId])
  @@index([tenantId])
}

// ── Class Ratings ──

enum RatingSource {
  email
  app_sheet
  class_page
}

model ClassRating {
  id         String       @id @default(cuid())
  tenantId   String
  userId     String
  classId    String
  rating     Int          // 1-5
  reasons    String[]
  comment    String?
  source     RatingSource
  emailToken String?      @unique
  createdAt  DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation("UserClassRatings", fields: [userId], references: [id], onDelete: Cascade)
  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([tenantId, classId])
  @@index([tenantId, createdAt])
}

model RatingReason {
  id          String     @id @default(cuid())
  tenantId    String
  classTypeId String?
  text        String
  emoji       String
  order       Int        @default(0)
  active      Boolean    @default(true)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  classType ClassType? @relation(fields: [classTypeId], references: [id], onDelete: Cascade)

  @@index([tenantId, classTypeId])
}

// ── Highlights (marketing banners on feed) ──

model Highlight {
  id          String   @id @default(cuid())
  tenantId    String
  title       String?
  subtitle    String?
  imageUrl    String
  linkUrl     String
  isExternal  Boolean  @default(false)
  position    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clicks HighlightClick[]

  @@index([tenantId, isActive])
}

model HighlightClick {
  id          String    @id @default(cuid())
  highlightId String
  userId      String?
  userName    String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  highlight Highlight @relation(fields: [highlightId], references: [id], onDelete: Cascade)

  @@index([highlightId, createdAt])
}

// ── Discount Codes ──

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model DiscountCode {
  id              String       @id @default(cuid())
  tenantId        String
  code            String       // e.g. "WELCOME20"
  description     String?
  type            DiscountType @default(PERCENTAGE)
  value           Float        // percentage (0-100) or fixed amount
  currency        String?      // required when type = FIXED_AMOUNT
  maxUses         Int?         // null = unlimited
  usedCount       Int          @default(0)
  maxUsesPerUser  Int?         // null = unlimited per user
  minPurchase     Float?       // minimum cart amount to apply
  validFrom       DateTime     @default(now())
  validUntil      DateTime?    // null = no expiry
  isActive        Boolean      @default(true)
  packageIds      String[]     @default([]) // empty = applies to all packages
  stripeCouponId  String?      // Stripe coupon id for syncing
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions DiscountRedemption[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([code])
}

model DiscountRedemption {
  id              String   @id @default(cuid())
  discountCodeId  String
  userId          String?
  userPackageId   String?  // the package purchase this was applied to
  originalAmount  Float
  discountAmount  Float
  finalAmount     Float
  createdAt       DateTime @default(now())

  discountCode DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)

  @@index([discountCodeId])
  @@index([userId])
}

// ── Gift Packages (admin-gifted) ──

model GiftPackage {
  id              String   @id @default(cuid())
  tenantId        String
  recipientId     String   // user who receives the gift
  packageId       String   // the package template
  userPackageId   String?  // the created UserPackage
  giftedById      String   // admin who gifted it
  reason          String?  // why it was gifted (tracking/audit)
  notes           String?  // internal notes
  createdAt       DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recipientId])
  @@index([giftedById])
  @@index([tenantId, createdAt])
}

// ── Spark AI Feature Requests ──

model SparkFeatureRequest {
  id          String   @id @default(cuid())
  tenantId    String
  adminUserId String
  request     String   @db.Text
  category    String?
  sparkNote   String?  @db.Text
  adminName   String?
  studioName  String?
  isResolved  Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([isResolved, createdAt])
}
