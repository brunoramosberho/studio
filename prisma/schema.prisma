// ── Gamificación: catálogo + progreso por tenant (studio_id del spec → tenantId) ──

enum AchievementCategory {
  MILESTONE
  STREAK
  BIRTHDAY
  SOCIAL
  CUSTOM
}

enum AchievementTriggerType {
  CLASS_COUNT
  STREAK_DAYS
  BIRTHDAY
  BIRTHDAY_CLASS
  MANUAL
  REFERRAL
  FIRST_7AM_CLASS
  FIRST_9PM_CLASS
  FIVE_CLASSES_ONE_WEEK
  FIRST_CLASS_OF_TYPE
  WEEKLY_STREAK
  CLASS_VARIETY
  COMEBACK
  CLASSES_IN_WEEK
}

enum AchievementRewardType {
  NONE
  DISCOUNT_PERCENT
  FREE_CLASS
}

enum MemberRewardSourceType {
  ACHIEVEMENT
  LEVEL_UP
  MANUAL
}

enum MemberRewardKind {
  DISCOUNT_CODE
  FREE_CLASS
  CUSTOM
}

/// Definición de logro: tenantId null = sistema (todos los estudios). key único global.
model Achievement {
  id            String                 @id @default(cuid())
  tenantId      String?
  tenant        Tenant?                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key           String                 @unique
  name          String
  description   String?
  icon          String                 @default("🏆")
  category      AchievementCategory
  triggerType   AchievementTriggerType
  triggerValue  Int?
  triggerConfig Json?
  rewardType    AchievementRewardType  @default(NONE)
  rewardValue   Json?
  isSystem      Boolean                @default(true)
  active        Boolean                @default(true)
  createdAt     DateTime               @default(now())
  memberEarned  MemberAchievement[]

  @@index([tenantId, active])
}

/// Niveles globales (Bronce → Elite), no por tenant.
model LoyaltyLevel {
  id             String           @id @default(cuid())
  sortOrder      Int              @unique
  name           String
  minClasses     Int              @unique
  icon           String
  color          String
  rewardOnUnlock Json?
  members        MemberProgress[] @relation("MemberCurrentLevel")

  @@index([minClasses])
}

/// Estado de gamificación por miembro y tenant.
model MemberProgress {
  userId               String
  tenantId             String
  user                 User          @relation("MemberProgressUser", fields: [userId], references: [id], onDelete: Cascade)
  tenant               Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  currentLevelId       String?
  currentLevel         LoyaltyLevel? @relation("MemberCurrentLevel", fields: [currentLevelId], references: [id])
  totalClassesAttended Int           @default(0)
  currentStreak        Int           @default(0)
  longestStreak        Int           @default(0)
  lastClassDate        DateTime?     @db.Date
  freeClassCredits     Int           @default(0)
  updatedAt            DateTime      @updatedAt

  @@id([userId, tenantId])
  @@index([tenantId])
}

/// Logro desbloqueado (antes UserAchievement + achievementType string).
model MemberAchievement {
  id              String      @id @default(cuid())
  userId          String
  tenantId        String
  user            User        @relation("MemberAchievements", fields: [userId], references: [id], onDelete: Cascade)
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  achievementId   String
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  earnedAt        DateTime    @default(now())
  metadata        Json?
  rewardApplied   Boolean     @default(false)
  rewardAppliedAt DateTime?
  feedEventId     String?     @unique
  feedEvent       FeedEvent?  @relation(fields: [feedEventId], references: [id], onDelete: SetNull)

  @@unique([userId, tenantId, achievementId])
  @@index([userId, tenantId])
  @@index([achievementId])
}

model MemberReward {
  id         String                 @id @default(cuid())
  userId     String
  tenantId   String
  user       User                   @relation("MemberRewardsUser", fields: [userId], references: [id], onDelete: Cascade)
  tenant     Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceType MemberRewardSourceType
  sourceId   String?
  rewardKind MemberRewardKind
  rewardData Json
  appliedAt  DateTime               @default(now())
  expiresAt  DateTime?
  consumedAt DateTime?

  @@index([userId, tenantId])
  @@index([tenantId])
}

/// Per-tenant gamification settings: toggle sections, override names/icons, define auto-rewards.
model TenantGamificationConfig {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  levelsEnabled        Boolean  @default(true)
  achievementsEnabled  Boolean  @default(true)
  autoRewardsEnabled   Boolean  @default(false)
  levelOverrides       Json?
  achievementOverrides Json?
  autoRewards          Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  type        String
  actorId     String?
  actor       User?     @relation("NotificationActor", fields: [actorId], references: [id])
  feedEventId String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
  @@index([tenantId])
}

