  userPackage   UserPackage @relation(fields: [userPackageId], references: [id], onDelete: Cascade)
  classTypeId   String
  classType     ClassType   @relation(fields: [classTypeId], references: [id])
  creditsTotal  Int
  creditsUsed   Int         @default(0)

  @@unique([userPackageId, classTypeId])
  @@index([userPackageId])
}

// ── Location Hierarchy ──

model Country {
  id             String    @id @default(cuid())
  name           String
  code           String    @unique
  // ISO 4217 currency code (e.g. "EUR", "MXN", "USD").
  currency       String    @default("EUR")
  // Display symbol for UI ("€", "$", "£", "MX$", etc.). Prefer ASCII for forms.
  currencySymbol String    @default("€")
  // BCP 47 locale used to format numbers/dates inside this country (e.g. "es-ES", "es-MX", "en-US").
  intlLocale     String    @default("es-ES")
  cities         City[]
  packages       Package[]
  users          User[]
