generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Multi-tenant ──

model Tenant {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  isActive        Boolean  @default(true)

  // Branding (migrated from StudioSettings)
  tagline         String   @default("Pilates & Wellness")
  slogan          String   @default("Muévete. Respira. Floréce.")
  metaDescription String   @default("Tu espacio de Pilates y bienestar.")
  logoUrl         String?
  appIconUrl      String?
  fontPairing     String   @default("jakarta-dmsans")
  colorBg         String   @default("#FAF9F6")
  colorFg         String   @default("#1C1917")
  colorSurface    String   @default("#F5F2ED")
  colorAccent     String   @default("#C9A96E")
  colorAccentSoft String   @default("#E8D9BF")
  colorMuted      String   @default("#8C8279")
  colorBorder     String   @default("#E8E2D9")
  colorCoach      String   @default("#2D5016")
  colorAdmin      String   @default("#1A2C4E")
  coachIconSvg    String?  @db.Text

  stripeCustomerId String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships       Membership[]
  studios           Studio[]
  classTypes        ClassType[]
  coachProfiles     CoachProfile[]
  classes           Class[]
  bookings          Booking[]
  waitlists         Waitlist[]
  packages          Package[]
  userPackages      UserPackage[]
  rooms             Room[]
  feedEvents        FeedEvent[]
  notifications     Notification[]
  achievements      UserAchievement[]
  friendships       Friendship[]
  pushSubscriptions PushSubscription[]
  productCategories ProductCategory[]
  products          Product[]
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ── Auth (global) ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PendingLogin {
  id           String   @id @default(cuid())
  email        String
  token        String   @unique
  approved     Boolean  @default(false)
  sessionToken String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── Users (global) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT) // deprecated: kept for migration, use Membership.role
  isSuperAdmin  Boolean   @default(false)
  phone         String?
  birthday      DateTime?
  countryId     String?
  country       Country?  @relation(fields: [countryId], references: [id])
  cityId        String?
  city          City?     @relation(fields: [cityId], references: [id])
  instagramUser String?
  stravaUser    String?
  createdAt     DateTime  @default(now())

  memberships  Membership[]
  packages     UserPackage[]
  bookings     Booking[]
  coachProfiles CoachProfile[]
  accounts     Account[]
  sessions     Session[]
  waitlists    Waitlist[]

  feedEvents           FeedEvent[]      @relation("FeedEventAuthor")
  likes                Like[]           @relation("UserLikes")
  comments             Comment[]        @relation("UserComments")
  photos               Photo[]          @relation("UserPhotos")
  achievements         UserAchievement[] @relation("UserAchievements")
  notifications        Notification[]   @relation("UserNotifications")
  notificationsActed   Notification[]   @relation("NotificationActor")
  friendshipsRequested Friendship[]     @relation("FriendshipRequester")
  friendshipsReceived  Friendship[]     @relation("FriendshipAddressee")
  favoriteSongs        FavoriteSong[]   @relation("UserFavoriteSongs")
  pushSubscriptions    PushSubscription[] @relation("UserPushSubscriptions")

  @@index([countryId])
  @@index([cityId])
}

model FavoriteSong {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFavoriteSongs", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  artist    String
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  CLIENT
  COACH
  ADMIN
}

// ── Studio domain models (tenant-scoped) ──

model CoachProfile {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  bio         String?
  specialties String[]
  photoUrl    String?
  color       String   @default("#C9A96E")
  classes     Class[]

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model ClassType {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int
  level       Level    @default(ALL)
  color       String
  icon        String?
  mediaUrl    String?
  tags        String[] @default([])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  classes     Class[]
  rooms       Room[]   @relation("RoomClassTypes")
  packages    Package[] @relation("PackageClassTypes")

  @@index([tenantId])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

model Class {
  id          String      @id @default(cuid())
  classTypeId String
  classType   ClassType   @relation(fields: [classTypeId], references: [id])
  coachId     String
  coach       CoachProfile @relation(fields: [coachId], references: [id])
  roomId      String
  room        Room         @relation(fields: [roomId], references: [id])
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  status      ClassStatus @default(SCHEDULED)
  isRecurring Boolean     @default(false)
  recurringId String?
  notes       String?
  tag         String?
  bookings    Booking[]
  waitlist    Waitlist[]

  @@index([startsAt])
  @@index([classTypeId])
  @@index([coachId])
  @@index([roomId])
  @@index([status])
  @@index([tenantId])
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model Booking {
  id          String        @id @default(cuid())
  classId     String
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  guestEmail  String?
  guestName   String?
  spotNumber  Int?
  privacy     BookingPrivacy @default(PUBLIC)
  status      BookingStatus  @default(CONFIRMED)
  packageUsed    String?
  creditLost     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  reminderSentAt DateTime?

  @@unique([classId, spotNumber])
  @@index([classId])
  @@index([userId])
  @@index([tenantId])
}

enum BookingPrivacy {
  PUBLIC
  PRIVATE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model Waitlist {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  position  Int
  createdAt DateTime @default(now())

  @@index([classId])
  @@index([tenantId])
}

enum PackageType {
  OFFER
  PACK
  SUBSCRIPTION
}

model Package {
  id            String        @id @default(cuid())
  name          String
  description   String?
  type          PackageType   @default(PACK)
  credits       Int?
  validDays     Int
  price         Float
  currency      String        @default("MXN")
  isPromo       Boolean       @default(false)
  isActive      Boolean       @default(true)
  stripePriceId String?
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  countryId     String?
  country       Country?      @relation(fields: [countryId], references: [id])
  classTypes    ClassType[]   @relation("PackageClassTypes")
  recurringInterval String?
  sortOrder     Int           @default(0)
  userPackages  UserPackage[]

  @@index([countryId])
  @@index([tenantId])
}

model UserPackage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id])
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  creditsTotal    Int?
  creditsUsed     Int      @default(0)
  expiresAt       DateTime
  stripePaymentId String?
  purchasedAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId])
}

// ── Location Hierarchy ──

model Country {
  id       String    @id @default(cuid())
  name     String
  code     String    @unique
  cities   City[]
  packages Package[]
  users    User[]
}

model City {
  id        String   @id @default(cuid())
  name      String
  countryId String
  country   Country  @relation(fields: [countryId], references: [id])
  studios   Studio[]
  users     User[]

  @@index([countryId])
}

model Studio {
  id        String  @id @default(cuid())
  name      String
  address   String?
  cityId    String
  city      City    @relation(fields: [cityId], references: [id])
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  rooms     Room[]

  @@index([cityId])
  @@index([tenantId])
}

model Room {
  id          String      @id @default(cuid())
  name        String
  studioId    String
  studio      Studio      @relation(fields: [studioId], references: [id])
  classTypes  ClassType[] @relation("RoomClassTypes")
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  maxCapacity Int
  layout      Json?
  classes     Class[]

  @@index([studioId])
  @@index([tenantId])
}

// ── Social Graph ──

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, addresseeId, tenantId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@index([tenantId])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ── Social Layer ──

enum FeedEventType {
  CLASS_COMPLETED
  CLASS_RESERVED
  ACHIEVEMENT_UNLOCKED
  STUDIO_POST
}

enum FeedVisibility {
  STUDIO_WIDE
  FRIENDS_ONLY
  PRIVATE
}

model FeedEvent {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation("FeedEventAuthor", fields: [userId], references: [id])
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  eventType  FeedEventType
  payload    Json
  visibility FeedVisibility @default(STUDIO_WIDE)
  isPinned   Boolean        @default(false)
  createdAt  DateTime       @default(now())
  likes      Like[]
  comments   Comment[]
  photos     Photo[]

  @@index([createdAt])
  @@index([userId])
  @@index([eventType])
  @@index([tenantId])
}

model Like {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserLikes", fields: [userId], references: [id])
  feedEventId String
  feedEvent   FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  type        String    @default("like")
  createdAt   DateTime  @default(now())

  @@unique([userId, feedEventId])
  @@index([feedEventId])
}

model Comment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserComments", fields: [userId], references: [id])
  feedEventId String
  feedEvent   FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  parentId    String?
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([feedEventId])
}

model Photo {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("UserPhotos", fields: [userId], references: [id])
  feedEventId  String
  feedEvent    FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  mimeType     String    @default("image/jpeg")
  createdAt    DateTime  @default(now())

  @@index([feedEventId])
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserAchievements", fields: [userId], references: [id])
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  achievementType String
  metadata        Json?
  earnedAt        DateTime @default(now())

  @@unique([userId, tenantId, achievementType])
  @@index([userId])
  @@index([tenantId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id])
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  type        String
  actorId     String?
  actor       User?     @relation("NotificationActor", fields: [actorId], references: [id])
  feedEventId String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
  @@index([tenantId])
}

// ── Push Notifications ──

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserPushSubscriptions", fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
}

// ── Shop ──

model ProductCategory {
  id        String    @id @default(cuid())
  name      String
  position  Int       @default(0)
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  products  Product[]
  createdAt DateTime  @default(now())

  @@index([tenantId])
}

model Product {
  id          String           @id @default(cuid())
  name        String
  description String?
  price       Float
  currency    String           @default("MXN")
  imageUrl    String?
  isVisible   Boolean          @default(true)
  isActive    Boolean          @default(true)
  externalUrl String?
  position    Int              @default(0)
  categoryId  String
  category    ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId])
  @@index([categoryId])
}

// ── Studio Branding (deprecated: kept for migration, use Tenant) ──

model StudioSettings {
  id              String   @id @default("singleton")
  studioName      String   @default("Flō")
  tagline         String   @default("Pilates & Wellness")
  slogan          String   @default("Muévete. Respira. Floréce.")
  metaDescription String   @default("Tu espacio de Pilates y bienestar.")
  logoUrl         String?
  appIconUrl      String?
  fontPairing     String   @default("jakarta-dmsans")
  colorBg         String   @default("#FAF9F6")
  colorFg         String   @default("#1C1917")
  colorSurface    String   @default("#F5F2ED")
  colorAccent     String   @default("#C9A96E")
  colorAccentSoft String   @default("#E8D9BF")
  colorMuted      String   @default("#8C8279")
  colorBorder     String   @default("#E8E2D9")
  colorCoach      String   @default("#2D5016")
  colorAdmin      String   @default("#1A2C4E")
  coachIconSvg    String?  @db.Text
  updatedAt       DateTime @updatedAt
}
