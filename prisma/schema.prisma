generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)
  phone         String?
  createdAt     DateTime  @default(now())

  packages     UserPackage[]
  bookings     Booking[]
  coachProfile CoachProfile?
  accounts     Account[]
  sessions     Session[]
  waitlists    Waitlist[]
}

enum Role {
  CLIENT
  COACH
  ADMIN
}

model CoachProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  specialties String[]
  photoUrl    String?
  color       String   @default("#C9A96E")
  classes     Class[]
}

model ClassType {
  id          String  @id @default(cuid())
  name        String
  description String?
  duration    Int
  maxCapacity Int
  level       Level   @default(ALL)
  color       String
  icon        String?
  classes     Class[]
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

model Class {
  id          String      @id @default(cuid())
  classTypeId String
  classType   ClassType   @relation(fields: [classTypeId], references: [id])
  coachId     String
  coach       CoachProfile @relation(fields: [coachId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  location    String?
  status      ClassStatus @default(SCHEDULED)
  isRecurring Boolean     @default(false)
  recurringId String?
  notes       String?
  bookings    Booking[]
  waitlist    Waitlist[]

  @@index([startsAt])
  @@index([classTypeId])
  @@index([coachId])
  @@index([status])
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model Booking {
  id          String        @id @default(cuid())
  classId     String
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  guestEmail  String?
  guestName   String?
  status      BookingStatus @default(CONFIRMED)
  packageUsed String?
  createdAt   DateTime      @default(now())

  @@index([classId])
  @@index([userId])
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model Waitlist {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  Int
  createdAt DateTime @default(now())

  @@index([classId])
}

model Package {
  id            String        @id @default(cuid())
  name          String
  description   String?
  credits       Int?
  validDays     Int
  price         Float
  currency      String        @default("MXN")
  isPromo       Boolean       @default(false)
  isActive      Boolean       @default(true)
  stripePriceId String?
  userPackages  UserPackage[]
}

model UserPackage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id])
  creditsTotal    Int?
  creditsUsed     Int      @default(0)
  expiresAt       DateTime
  stripePaymentId String?
  purchasedAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}
