generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT)
  phone         String?
  birthday      DateTime?
  createdAt     DateTime  @default(now())

  packages     UserPackage[]
  bookings     Booking[]
  coachProfile CoachProfile?
  accounts     Account[]
  sessions     Session[]
  waitlists    Waitlist[]

  feedEvents           FeedEvent[]      @relation("FeedEventAuthor")
  likes                Like[]           @relation("UserLikes")
  comments             Comment[]        @relation("UserComments")
  photos               Photo[]          @relation("UserPhotos")
  achievements         UserAchievement[] @relation("UserAchievements")
  notifications        Notification[]   @relation("UserNotifications")
  notificationsActed   Notification[]   @relation("NotificationActor")
  friendshipsRequested Friendship[]     @relation("FriendshipRequester")
  friendshipsReceived  Friendship[]     @relation("FriendshipAddressee")
  favoriteSongs        FavoriteSong[]   @relation("UserFavoriteSongs")
}

model FavoriteSong {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFavoriteSongs", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  artist    String
  createdAt DateTime @default(now())

  @@index([userId])
}

enum Role {
  CLIENT
  COACH
  ADMIN
}

model CoachProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  specialties String[]
  photoUrl    String?
  color       String   @default("#C9A96E")
  classes     Class[]
}

model ClassType {
  id          String  @id @default(cuid())
  name        String
  description String?
  duration    Int
  maxCapacity Int
  level       Level   @default(ALL)
  color       String
  icon        String?
  classes     Class[]
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

model Class {
  id          String      @id @default(cuid())
  classTypeId String
  classType   ClassType   @relation(fields: [classTypeId], references: [id])
  coachId     String
  coach       CoachProfile @relation(fields: [coachId], references: [id])
  startsAt    DateTime
  endsAt      DateTime
  location    String?
  status      ClassStatus @default(SCHEDULED)
  isRecurring Boolean     @default(false)
  recurringId String?
  notes       String?
  tag         String?
  bookings    Booking[]
  waitlist    Waitlist[]

  @@index([startsAt])
  @@index([classTypeId])
  @@index([coachId])
  @@index([status])
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model Booking {
  id          String        @id @default(cuid())
  classId     String
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?         @relation(fields: [userId], references: [id])
  guestEmail  String?
  guestName   String?
  spotNumber  Int?
  privacy     BookingPrivacy @default(PUBLIC)
  status      BookingStatus  @default(CONFIRMED)
  packageUsed String?
  createdAt   DateTime       @default(now())

  @@unique([classId, spotNumber])
  @@index([classId])
  @@index([userId])
}

enum BookingPrivacy {
  PUBLIC
  PRIVATE
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

model Waitlist {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  position  Int
  createdAt DateTime @default(now())

  @@index([classId])
}

model Package {
  id            String        @id @default(cuid())
  name          String
  description   String?
  credits       Int?
  validDays     Int
  price         Float
  currency      String        @default("MXN")
  isPromo       Boolean       @default(false)
  isActive      Boolean       @default(true)
  stripePriceId String?
  userPackages  UserPackage[]
}

model UserPackage {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  packageId       String
  package         Package  @relation(fields: [packageId], references: [id])
  creditsTotal    Int?
  creditsUsed     Int      @default(0)
  expiresAt       DateTime
  stripePaymentId String?
  purchasedAt     DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ── Social Graph ──

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  requester   User             @relation("FriendshipRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  addresseeId String
  addressee   User             @relation("FriendshipAddressee", fields: [addresseeId], references: [id], onDelete: Cascade)
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ── Social Layer ──

enum FeedEventType {
  CLASS_COMPLETED
  CLASS_RESERVED
  ACHIEVEMENT_UNLOCKED
}

enum FeedVisibility {
  STUDIO_WIDE
  FRIENDS_ONLY
  PRIVATE
}

model FeedEvent {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation("FeedEventAuthor", fields: [userId], references: [id])
  eventType  FeedEventType
  payload    Json
  visibility FeedVisibility @default(STUDIO_WIDE)
  createdAt  DateTime       @default(now())
  likes      Like[]
  comments   Comment[]
  photos     Photo[]

  @@index([createdAt])
  @@index([userId])
  @@index([eventType])
}

model Like {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserLikes", fields: [userId], references: [id])
  feedEventId String
  feedEvent   FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  type        String    @default("like")
  createdAt   DateTime  @default(now())

  @@unique([userId, feedEventId])
  @@index([feedEventId])
}

model Comment {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserComments", fields: [userId], references: [id])
  feedEventId String
  feedEvent   FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  parentId    String?
  body        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([feedEventId])
}

model Photo {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation("UserPhotos", fields: [userId], references: [id])
  feedEventId  String
  feedEvent    FeedEvent @relation(fields: [feedEventId], references: [id], onDelete: Cascade)
  url          String
  thumbnailUrl String?
  mimeType     String    @default("image/jpeg")
  createdAt    DateTime  @default(now())

  @@index([feedEventId])
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation("UserAchievements", fields: [userId], references: [id])
  achievementType String
  metadata        Json?
  earnedAt        DateTime @default(now())

  @@unique([userId, achievementType])
  @@index([userId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("UserNotifications", fields: [userId], references: [id])
  type        String
  actorId     String?
  actor       User?     @relation("NotificationActor", fields: [actorId], references: [id])
  feedEventId String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt])
}

// ── Studio Branding ──

model StudioSettings {
  id              String   @id @default("singleton")
  studioName      String   @default("Flō")
  tagline         String   @default("Pilates & Wellness")
  slogan          String   @default("Muévete. Respira. Floréce.")
  metaDescription String   @default("Tu espacio de Pilates y bienestar.")
  logoUrl         String?
  fontPairing     String   @default("playfair-dmsans")
  colorBg         String   @default("#FAF9F6")
  colorFg         String   @default("#1C1917")
  colorSurface    String   @default("#F5F2ED")
  colorAccent     String   @default("#C9A96E")
  colorAccentSoft String   @default("#E8D9BF")
  colorMuted      String   @default("#8C8279")
  colorBorder     String   @default("#E8E2D9")
  colorCoach      String   @default("#2D5016")
  colorAdmin      String   @default("#1A2C4E")
  updatedAt       DateTime @updatedAt
}
