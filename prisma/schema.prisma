generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Platform SaaS (studio subscription to Mgic; not tenant-scoped) ──

/// Catalog row for Stripe Price IDs per logical plan and optional country.
/// Use `countryCode` `"__"` for the default/fallback price when no country-specific row exists.
model SaasPlan {
  id                   String   @id @default(cuid())
  planKey              String
  countryCode          String   @default("__")
  stripePriceId        String
  /// Optional Stripe Price ID for test mode (`Tenant.stripeSandboxMode`).
  stripePriceIdSandbox String?
  currency             String   @default("eur")
  /// Display cache only — Stripe Prices are billing source of truth.
  amountCents          Int?
  name                 String?
  sortOrder            Int      @default(0)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([planKey, countryCode])
  @@index([planKey, isActive])
  @@map("saas_plans")
}

// ── Multi-tenant ──

model Tenant {
  id       String  @id @default(cuid())
  slug     String  @unique
  name     String
  isActive Boolean @default(true)

  // Branding (migrated from StudioSettings)
  tagline           String  @default("Pilates & Wellness")
  slogan            String  @default("Muévete. Respira. Floréce.")
  metaDescription   String  @default("Tu espacio de Pilates y bienestar.")
  logoUrl           String?
  appIconUrl        String?
  fontPairing       String  @default("jakarta-dmsans")
  colorBg           String  @default("#FFFFFF")
  colorFg           String  @default("#18181B")
  colorSurface      String  @default("#FAFAFA")
  colorAccent       String  @default("#FF5A2C")
  colorAccentSoft   String  @default("#FFF1EE")
  colorMuted        String  @default("#71717A")
  colorBorder       String  @default("#E4E4E7")
  colorHeroBg       String  @default("#18181B")
  colorCoach        String  @default("#15803D")
  colorAdmin        String  @default("#1E40AF")
  coachIconSvg      String? @db.Text
  landingUrl        String?
  communityHeadline String  @default("Tu comunidad en movimiento")

  stripeCustomerId          String? // cus_xxx — Tenant as customer of Magic Payments (SaaS fee)
  stripeAccountId           String? // acct_xxx — Connected Account for receiving student payments
  stripeAccountStatus       String? // 'pending' | 'active' | 'restricted'
  stripeSubscriptionId      String? // sub_xxx — Active SaaS subscription
  stripePlanId              String? // price_xxx — Contracted plan
  subscriptionStatus        String? // 'active' | 'past_due' | 'canceled' | 'trialing'
  trialEndsAt               DateTime?
  applicationFeePercent     Float     @default(0) // % fee Magic charges per transaction
  /// Negotiated SaaS price: when set, overrides `SaasPlan` catalog for new subscriptions.
  saasStripePriceIdOverride String?
  /// When true, API calls use Stripe test keys (`STRIPE_SECRET_KEY_*_TEST` / `STRIPE_SECRET_KEY_TEST`).
  stripeSandboxMode         Boolean   @default(false)

  zoneRedDays    Int @default(14)
  zoneYellowDays Int @default(30)

  studioOpenTime  String @default("07:00")
  studioCloseTime String @default("21:00")
  operatingDays   Int[]  @default([0, 1, 2, 3, 4])

  // How many days of schedule are visible to clients on the public /schedule page
  visibleScheduleDays Int @default(7)

  // When true, the assigned coach is hidden from clients on the schedule, booking
  // flow, confirmation surfaces, /my upcoming classes, reminders and emails. The
  // coach is only revealed once the class has ended (history + ratings). Staff
  // surfaces (admin/coach portal) are unaffected. The /instructors directory
  // remains visible because it isn't tied to a specific class.
  hideCoachUntilClassEnds Boolean @default(false)

  notifyEmailOnRequest    Boolean @default(true)
  notifyPushOnRequest     Boolean @default(true)
  notifyGapDetected       Boolean @default(true)
  notifyWeeklySummary     Boolean @default(false)
  notifyAutoRejectTimeout Boolean @default(false)

  locale String @default("es") // "en" | "es"

  // Default country for this tenant. Drives currency/symbol/intl locale for the
  // whole app unless overridden per Studio/Package. Nullable for backfill; once
  // the tenant has at least one Studio, this should point to the same Country
  // as the primary Studio's City.
  defaultCountryId String?
  defaultCountry   Country? @relation("TenantDefaultCountry", fields: [defaultCountryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships               Membership[]
  studios                   Studio[]
  classTypes                ClassType[]
  coachProfiles             CoachProfile[]
  classes                   Class[]
  bookings                  Booking[]
  waitlists                 Waitlist[]
  spotNotifyMe              ClassNotifyMe[]
  packages                  Package[]
  userPackages              UserPackage[]
  rooms                     Room[]
  feedEvents                FeedEvent[]
  notifications             Notification[]
  achievements              Achievement[]
  memberProgress            MemberProgress[]
  memberRewards             MemberReward[]
  memberAchievements        MemberAchievement[]
  blockedSpots              BlockedSpot[]
  friendships               Friendship[]
  pushSubscriptions         PushSubscription[]
  productCategories         ProductCategory[]
  products                  Product[]
  productStudioAvailability ProductStudioAvailability[]
  bookingProductOrders      BookingProductOrder[]
  songRequests              ClassSongRequest[]
  coachPayRates             CoachPayRate[]
  coachAvailabilityBlocks   CoachAvailabilityBlock[]
  substitutionRequests      SubstitutionRequest[]
  checkIns                  CheckIn[]

  instagramIntegration InstagramIntegration?

  platformConfigs  StudioPlatformConfig[]
  platformQuotas   SchedulePlatformQuota[]
  platformBookings PlatformBooking[]
  platformAlerts   PlatformAlert[]

  wellhubProducts  WellhubProduct[]
  wellhubUserLinks WellhubUserLink[]

  waivers          Waiver[]
  waiverSignatures WaiverSignature[]

  analyticsConfig TenantAnalyticsConfig?
  linkClicks      LinkClick[]
  linkConversions LinkConversion[]

  referralConfig  ReferralConfig?
  referralRewards ReferralReward[]

  gamificationConfig TenantGamificationConfig?

  conversionConfig MembershipConversionConfig?
  nudgeEvents      NudgeEvent[]
  introOfferClaims IntroOfferClaim[]

  // Cancellation & no-show policies
  cancellationWindowHours Int     @default(12)
  noShowPenaltyEnabled    Boolean @default(false)
  noShowPenaltyType       String  @default("CREDIT_LOSS") // DEPRECATED — use noShowLoseCredit / noShowChargeFee
  noShowPenaltyAmount     Float? // Fee amount for credit/pack members (and unlimited if noShowFeeAmountUnlimited is null)

  // Per-segment penalty flags. noShowLoseCredit only affects pack/credit bookings
  // (unlimited bookings never consume a credit). noShowChargeFee enables monetary
  // charging; amounts split between regular and unlimited members when different
  // fees apply.
  noShowLoseCredit         Boolean @default(true)
  noShowChargeFee          Boolean @default(false)
  noShowFeeAmountUnlimited Float? // If null, noShowPenaltyAmount applies to unlimited too

  // Grace window (in hours) before pending penalties auto-confirm. 0 = confirm
  // immediately on the next auto-confirm cron run. Very large values effectively
  // require manual confirmation.
  noShowPenaltyGraceHours Int @default(24)

  taxRate           Float  @default(0.21)
  tpvFeePercent     Float?
  tpvFeeFixed       Float?
  tpvSettlementDays Int?

  stripePayments      StripePayment[]
  stripeCustomers     StripeCustomer[]
  memberSubscriptions MemberSubscription[]
  posTransactions     PosTransaction[]
  classRatings        ClassRating[]
  ratingReasons       RatingReason[]

  highlightsEnabled Boolean     @default(false)
  highlights        Highlight[]

  feedShowDisciplines     Boolean @default(true)
  feedDisciplineThreshold Int?    @default(5)

  discountCodes        DiscountCode[]
  giftPackages         GiftPackage[]
  sparkFeatureRequests SparkFeatureRequest[]

  entitlements  Entitlement[]
  revenueEvents RevenueEvent[]

  pendingPenalties PendingPenalty[]
  debts            Debt[]

  onDemandVideos         OnDemandVideo[]
  onDemandConfig         OnDemandConfig?
  onDemandStreamSessions OnDemandStreamSession[]
}

model InstagramIntegration {
  id       String @id @default(cuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  pageId     String
  igUserId   String
  igUsername String?

  accessToken String    @db.Text
  tokenType   String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([igUserId])
}

enum MemberLifecycleStage {
  lead
  installed
  purchased
  booked
  attended
  member
}

model Membership {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role           Role      @default(CLIENT)
  pwaInstalledAt DateTime?
  lastSeenAt     DateTime?
  createdAt      DateTime  @default(now())

  lifecycleStage     MemberLifecycleStage @default(lead)
  lifecycleUpdatedAt DateTime?
  firstPurchaseAt    DateTime?
  firstBookingAt     DateTime?
  firstAttendanceAt  DateTime?
  becameMemberAt     DateTime?

  referralCode           String?      @unique
  referredByMembershipId String?
  referredByMembership   Membership?  @relation("MemberReferrals", fields: [referredByMembershipId], references: [id])
  referrals              Membership[] @relation("MemberReferrals")

  referralRewards ReferralReward[] @relation("MemberReferralRewards")

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ── Referrals ──

model ReferralConfig {
  id        String  @id @default(cuid())
  tenantId  String  @unique
  isEnabled Boolean @default(true)

  triggerStage MemberLifecycleStage @default(attended)

  referrerRewardType  ReferralRewardType @default(manual)
  referrerRewardValue Float?
  referrerRewardText  String?
  referrerRewardWhen  String?

  refereeRewardType  ReferralRewardType @default(manual)
  refereeRewardValue Float?
  refereeRewardText  String?
  refereeRewardWhen  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum ReferralRewardType {
  class_credit
  discount
  days_free
  manual
}

model ReferralReward {
  id           String             @id @default(cuid())
  tenantId     String
  membershipId String
  referralId   String
  type         String // 'referrer' | 'referee'
  rewardType   ReferralRewardType
  rewardValue  Float?
  rewardText   String?
  status       String             @default("pending") // 'pending' | 'delivered' | 'expired'
  deliveredAt  DateTime?
  createdAt    DateTime           @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership @relation("MemberReferralRewards", fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([tenantId, membershipId])
  @@index([tenantId, status])
}

// ── Auth (global) ──

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PendingLogin {
  id           String   @id @default(cuid())
  email        String
  token        String   @unique
  approved     Boolean  @default(false)
  sessionToken String?
  attempts     Int      @default(0)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── Users (global) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENT) // deprecated: kept for migration, use Membership.role
  isSuperAdmin  Boolean   @default(false)
  phone         String?
  birthday      DateTime?
  countryId     String?
  country       Country?  @relation(fields: [countryId], references: [id])
  cityId        String?
  city          City?     @relation(fields: [cityId], references: [id])
  gender        String? // "male" | "female" | "other" | null — AI-guessed on signup, editable by user
  instagramUser String?
  stravaUser    String?
  locale        String? // null = inherit from tenant
  createdAt     DateTime  @default(now())

  memberships   Membership[]
  packages      UserPackage[]
  bookings      Booking[]
  coachProfiles CoachProfile[]
  accounts      Account[]
  sessions      Session[]
  waitlists     Waitlist[]
  spotNotifyMe  ClassNotifyMe[]

  feedEvents               FeedEvent[]              @relation("FeedEventAuthor")
  likes                    Like[]                   @relation("UserLikes")
  comments                 Comment[]                @relation("UserComments")
  photos                   Photo[]                  @relation("UserPhotos")
  memberAchievements       MemberAchievement[]      @relation("MemberAchievements")
  memberProgressRows       MemberProgress[]         @relation("MemberProgressUser")
  memberRewards            MemberReward[]           @relation("MemberRewardsUser")
  notifications            Notification[]           @relation("UserNotifications")
  notificationsActed       Notification[]           @relation("NotificationActor")
  friendshipsRequested     Friendship[]             @relation("FriendshipRequester")
  friendshipsReceived      Friendship[]             @relation("FriendshipAddressee")
  favoriteSongs            FavoriteSong[]           @relation("UserFavoriteSongs")
  songRequests             ClassSongRequest[]       @relation("UserSongRequests")
  blockedSpots             BlockedSpot[]            @relation("UserBlockedSpots")
  pushSubscriptions        PushSubscription[]       @relation("UserPushSubscriptions")
  wearableConnections      UserWearableConnection[] @relation("UserWearableConnections")
  coachAvailabilityBlocks  CoachAvailabilityBlock[] @relation("CoachAvailabilityBlocks")
  memberCheckIns           CheckIn[]                @relation("MemberCheckIns")
  staffCheckIns            CheckIn[]                @relation("StaffCheckIns")
  waiverSignatures         WaiverSignature[]        @relation("MemberWaiverSignatures")
  nudgeEvents              NudgeEvent[]             @relation("UserNudgeEvents")
  introOfferClaims         IntroOfferClaim[]        @relation("UserIntroOfferClaims")
  stripeCustomerRecords    StripeCustomer[]         @relation("UserStripeCustomers")
  stripePayments           StripePayment[]          @relation("UserStripePayments")
  memberSubscriptions      MemberSubscription[]
  posTransactionsProcessed PosTransaction[]         @relation("PosProcessedBy")
  posTransactionsMember    PosTransaction[]         @relation("PosMember")
  classRatings             ClassRating[]            @relation("UserClassRatings")
  entitlements             Entitlement[]
  pendingPenalties         PendingPenalty[]         @relation("UserPendingPenalties")
  bookingProductOrders     BookingProductOrder[]    @relation("UserBookingProductOrders")
  debts                    Debt[]                   @relation("UserDebts")
  debtsResolved            Debt[]                   @relation("DebtResolver")
  onDemandStreamSessions   OnDemandStreamSession[]
  wellhubUserLinks         WellhubUserLink[]

  @@index([countryId])
  @@index([cityId])
}

model FavoriteSong {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation("UserFavoriteSongs", fields: [userId], references: [id], onDelete: Cascade)
  title          String
  artist         String
  spotifyTrackId String?
  albumArt       String?
  previewUrl     String?
  createdAt      DateTime @default(now())

  @@index([userId])
}

enum Role {
  CLIENT
  COACH
  FRONT_DESK
  ADMIN
}

// ── Studio domain models (tenant-scoped) ──

model CoachProfile {
  id                     String         @id @default(cuid())
  name                   String
  userId                 String?
  user                   User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId               String
  tenant                 Tenant         @relation(fields: [tenantId], references: [id])
  bio                    String?
  specialties            String[]
  photoUrl               String?
  color                  String         @default("#C9A96E")
  classes                Class[]        @relation("ClassCurrentCoach")
  classesAsOriginalCoach Class[]        @relation("ClassOriginalCoach")
  payRates               CoachPayRate[]

  onDemandVideos OnDemandVideo[]

  substitutionsRequested SubstitutionRequest[] @relation("SubstitutionRequestingCoach")
  substitutionsOriginal  SubstitutionRequest[] @relation("SubstitutionOriginalCoach")
  substitutionsTargeted  SubstitutionRequest[] @relation("SubstitutionTargetCoach")
  substitutionsAccepted  SubstitutionRequest[] @relation("SubstitutionAcceptedCoach")

  @@unique([userId, tenantId])
  @@index([tenantId])
}

enum CoachPayRateType {
  MONTHLY_FIXED
  PER_CLASS
  PER_STUDENT
  OCCUPANCY_TIER
}

model CoachPayRate {
  id              String           @id @default(cuid())
  coachProfileId  String
  coachProfile    CoachProfile     @relation(fields: [coachProfileId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  type            CoachPayRateType
  amount          Float
  currency        String           @default("MXN")
  classTypeId     String?
  classType       ClassType?       @relation(fields: [classTypeId], references: [id])
  occupancyTiers  Json?
  bonusMultiplier Float            @default(1)
  bonusDays       Json?
  bonusTags       String[]         @default([])
  isActive        Boolean          @default(true)
  effectiveFrom   DateTime         @default(now())
  effectiveTo     DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([coachProfileId])
  @@index([tenantId])
  @@index([classTypeId])
}

model ClassType {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int
  level       Level    @default(ALL)
  color       String
  icon        String?
  mediaUrl    String?
  tags        String[] @default([])

  showInFeed Boolean @default(true)

  // Revenue recognition: weight for proportional allocation from unlimited
  // subscriptions, and drop-in reference price used as the per-booking cap.
  // Formula: weight = dropInPriceCents / baseDropInPriceCents.
  revenueWeight    Decimal @default(1.0) @db.Decimal(4, 2)
  dropInPriceCents Int?

  tenantId                 String
  tenant                   Tenant                    @relation(fields: [tenantId], references: [id])
  classes                  Class[]
  rooms                    Room[]                    @relation("RoomClassTypes")
  packages                 Package[]                 @relation("PackageClassTypes")
  coachPayRates            CoachPayRate[]
  ratingReasons            RatingReason[]
  packageCreditAllocations PackageCreditAllocation[]
  userPackageCreditUsages  UserPackageCreditUsage[]
  onDemandVideos           OnDemandVideo[]

  // Wellhub mapping — populated when this ClassType is exposed in Wellhub.
  // wellhubClassId is the Wellhub "class" id (template). wellhubProductId is
  // the Wellhub product (yoga / swimming / virtual etc.) chosen for this type.
  wellhubClassId     Int?
  wellhubProductId   Int?
  wellhubCategoryIds Int[] @default([])

  @@unique([tenantId, wellhubClassId])
  @@index([tenantId])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL
}

model Class {
  id                   String                  @id @default(cuid())
  classTypeId          String
  classType            ClassType               @relation(fields: [classTypeId], references: [id])
  coachId              String
  coach                CoachProfile            @relation("ClassCurrentCoach", fields: [coachId], references: [id])
  originalCoachId      String?
  originalCoach        CoachProfile?           @relation("ClassOriginalCoach", fields: [originalCoachId], references: [id])
  roomId               String
  room                 Room                    @relation(fields: [roomId], references: [id])
  tenantId             String
  tenant               Tenant                  @relation(fields: [tenantId], references: [id])
  startsAt             DateTime
  endsAt               DateTime
  status               ClassStatus             @default(SCHEDULED)
  isRecurring          Boolean                 @default(false)
  recurringId          String?
  notes                String?
  tag                  String?
  bookings             Booking[]
  waitlist             Waitlist[]
  spotNotifyMe         ClassNotifyMe[]
  blockedSpots         BlockedSpot[]
  songRequests         ClassSongRequest[]
  songRequestsEnabled  Boolean                 @default(true)
  songRequestCriteria  String[]                @default(["ALL"])
  playlistTracks       ClassPlaylistTrack[]
  blockingNotes        String?
  checkIns             CheckIn[]
  platformQuotas       SchedulePlatformQuota[]
  platformBookings     PlatformBooking[]
  ratings              ClassRating[]
  ratingEmailSent      Boolean                 @default(false)
  entitlements         Entitlement[]
  revenueEvents        RevenueEvent[]
  substitutionRequests SubstitutionRequest[]

  // Wellhub Booking API mirror — wellhubSlotId is the Wellhub slot id for
  // this specific class occurrence. excluded = ClassType not mapped to Wellhub.
  wellhubSlotId     Int?              @unique
  wellhubSyncStatus WellhubSyncStatus @default(excluded)
  wellhubLastSyncAt DateTime?
  wellhubLastError  String?

  @@index([startsAt])
  @@index([classTypeId])
  @@index([coachId])
  @@index([roomId])
  @@index([status])
  @@index([tenantId])
  @@index([wellhubSyncStatus])
}

enum ClassStatus {
  SCHEDULED
  CANCELLED
  COMPLETED
}

model ClassSongRequest {
  id             String   @id @default(cuid())
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation("UserSongRequests", fields: [userId], references: [id], onDelete: Cascade)
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  title          String
  artist         String
  spotifyTrackId String?
  albumArt       String?
  previewUrl     String?
  createdAt      DateTime @default(now())

  @@unique([classId, userId])
  @@index([classId])
  @@index([tenantId])
}

model ClassPlaylistTrack {
  id             String   @id @default(cuid())
  classId        String
  class          Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title          String
  artist         String
  spotifyTrackId String?
  albumArt       String?
  previewUrl     String?
  position       Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([classId])
}

model Booking {
  id             String         @id @default(cuid())
  classId        String
  class          Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?          @relation(fields: [userId], references: [id])
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  guestEmail     String?
  guestName      String?
  spotNumber     Int?
  privacy        BookingPrivacy @default(PUBLIC)
  status         BookingStatus  @default(CONFIRMED)
  packageUsed    String?
  creditLost     Boolean        @default(false)
  createdAt      DateTime       @default(now())
  reminderSentAt DateTime?

  parentBookingId String?
  parentBooking   Booking?  @relation("BookingGuests", fields: [parentBookingId], references: [id], onDelete: SetNull)
  guestBookings   Booking[] @relation("BookingGuests")

  biometrics ClassBiometrics[]

  // Revenue recognition snapshot. imputedValueCents and classWeightSnapshot
  // are written at recognition time (drop-in/pack at booking, unlimited at
  // monthly close) so late edits to ClassType.revenueWeight or dropInPriceCents
  // don't retroactively alter historical accounting.
  imputedValueCents   Int?
  classWeightSnapshot Decimal?       @db.Decimal(4, 2)
  sourceEntitlementId String?
  sourceEntitlement   Entitlement?   @relation("SourceEntitlement", fields: [sourceEntitlementId], references: [id])
  revenueEvents       RevenueEvent[]

  pendingPenalty PendingPenalty?
  productOrder   BookingProductOrder?

  @@unique([classId, spotNumber])
  @@index([classId])
  @@index([userId])
  @@index([tenantId])
  @@index([parentBookingId])
  @@index([sourceEntitlementId])
}

enum PendingPenaltyStatus {
  pending
  confirmed
  waived
  reverted
}

// A no-show penalty awaiting admin review before the fee is charged and/or
// credit is formally consumed. Created by the cron or by manual NO_SHOW
// marking. Auto-confirms after the tenant's configured grace window, or is
// resolved manually from /admin/no-shows.
model PendingPenalty {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  classId   String
  userId    String?
  user      User?   @relation("UserPendingPenalties", fields: [userId], references: [id], onDelete: SetNull)

  loseCredit     Boolean @default(false) // Snapshot: does this penalty imply credit loss?
  chargeFee      Boolean @default(false) // Snapshot: should we charge a fee?
  feeAmountCents Int     @default(0) // Snapshot of fee amount at creation time
  isUnlimited    Boolean @default(false) // Was the booking on an unlimited package?

  status PendingPenaltyStatus @default(pending)

  createdAt      DateTime  @default(now())
  autoConfirmAt  DateTime? // When this will be auto-confirmed by the cron
  resolvedAt     DateTime?
  resolvedBy     String? // User id of admin who resolved; null when auto-confirmed
  resolutionNote String?

  revenueEventId String? // Set when status=confirmed and fee was recognized

  @@index([tenantId, status])
  @@index([tenantId, autoConfirmAt])
  @@index([classId])
  @@index([userId])
}

