# Supabase
DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email (Magic Link + Transactional)
RESEND_API_KEY=""
EMAIL_FROM="hola@magicpay.mx"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Anthropic
ANTHROPIC_API_KEY=""

# Spotify
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# Strava
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
STRAVA_WEBHOOK_SECRET=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# Super admin login (email + password for admin.ROOT_DOMAIN)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Dev login (/dev): fuerza qué usuario entra como coach o cliente (email del usuario en tu tenant).
# Si no las pones, se usa el membership más antiguo de ese rol (orderBy createdAt asc).
# DEV_LOGIN_COACH_EMAIL="coach@example.com"
# DEV_LOGIN_CLIENT_EMAIL="cliente@example.com"

